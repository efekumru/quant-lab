// Bollinger Bands Mean Reversion
// Buy on lower band touch, sell at mean or upper band
// @author efekumru

//@version=5
strategy("BB Mean Reversion", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95)

// Inputs
bb_length = input.int(20, "BB Length")
bb_mult = input.float(2.0, "BB Multiplier")
rsi_filter = input.int(35, "RSI Entry Filter")
take_profit = input.string("mean", "Take Profit Level", options=["mean", "upper"])

// Bollinger Bands
basis = ta.sma(close, bb_length)
dev = bb_mult * ta.stdev(close, bb_length)
upper = basis + dev
lower = basis - dev
bb_pct = (close - lower) / (upper - lower)

// RSI
rsi = ta.rsi(close, 14)

// Volume confirmation
vol_sma = ta.sma(volume, 20)
high_vol = volume > vol_sma * 1.2

// Entry: price touches lower band + RSI oversold + volume spike
long_entry = close <= lower and rsi < rsi_filter and high_vol

// Exit
tp_level = take_profit == "mean" ? basis : upper
long_exit = close >= tp_level
stop_loss = close < lower - dev  // below lower band by 1 more std dev

if long_entry
    strategy.entry("Long", strategy.long)

if long_exit
    strategy.close("Long")

if stop_loss
    strategy.close("Long", comment="SL")

// Plots
p_upper = plot(upper, "Upper", color=color.new(color.red, 70))
p_lower = plot(lower, "Lower", color=color.new(color.green, 70))
plot(basis, "Basis", color=color.gray)
fill(p_upper, p_lower, color=color.new(color.gray, 93))

// Entry markers
plotshape(long_entry, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small)
