// Momentum + RSI Filter Strategy
// Combines price momentum with RSI confirmation for trend entries
// @author efekumru

//@version=5
strategy("Momentum RSI Filter", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=95)

// Inputs
lookback = input.int(20, "Momentum Lookback", minval=5)
rsi_period = input.int(14, "RSI Period")
rsi_ob = input.int(70, "RSI Overbought")
rsi_os = input.int(30, "RSI Oversold")
atr_mult = input.float(2.0, "ATR Stop Multiplier")
atr_period = input.int(14, "ATR Period")

// Indicators
momentum = (close - close[lookback]) / close[lookback] * 100
rsi = ta.rsi(close, rsi_period)
atr = ta.atr(atr_period)
sma_200 = ta.sma(close, 200)

// Conditions
trend_up = close > sma_200
mom_positive = momentum > 2.0
rsi_not_ob = rsi < rsi_ob
rsi_oversold = rsi < rsi_os

// Entry
long_entry = trend_up and mom_positive and rsi_not_ob
long_exit = rsi > rsi_ob or close < sma_200

// Execute
if long_entry
    strategy.entry("Long", strategy.long)
    strategy.exit("SL", "Long", stop=close - atr * atr_mult)

if long_exit
    strategy.close("Long")

// Plots
plot(sma_200, "SMA 200", color=color.gray, linewidth=1)
bgcolor(strategy.position_size > 0 ? color.new(color.green, 90) : na)

// Info table
var table t = table.new(position.top_right, 2, 4)
if barstate.islast
    table.cell(t, 0, 0, "Momentum", bgcolor=color.new(color.gray, 80))
    table.cell(t, 1, 0, str.tostring(momentum, "#.#") + "%", bgcolor=color.new(color.gray, 80))
    table.cell(t, 0, 1, "RSI", bgcolor=color.new(color.gray, 80))
    table.cell(t, 1, 1, str.tostring(rsi, "#.#"), bgcolor=color.new(color.gray, 80))
    table.cell(t, 0, 2, "ATR", bgcolor=color.new(color.gray, 80))
    table.cell(t, 1, 2, str.tostring(atr, "#.##"), bgcolor=color.new(color.gray, 80))
    table.cell(t, 0, 3, "Trend", bgcolor=color.new(color.gray, 80))
    table.cell(t, 1, 3, trend_up ? "UP" : "DOWN", bgcolor=trend_up ? color.new(color.green, 80) : color.new(color.red, 80))
